# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true
NEXT_PUBLIC_ENABLE_FUND_CREATE_FLOW=true

# Platform Layer — يُستخدم مرة واحدة لإنشاء حساب المالك الأول
# POST /platform-auth/bootstrap مع header: x-bootstrap-secret: <هذه القيمة>
PLATFORM_BOOTSTRAP_SECRET=change-me-to-a-long-random-secret

# OAuth — مطلوب فقط عند تفعيل تسجيل الدخول الخارجي
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_ID=

# Payments — mock خارج الإنتاج عند تركها فارغة
