# Database
DATABASE_URL="postgres://postgres:YOUR_PASSWORD@localhost:5432/stgp_dev?sslmode=disable"

# JWT
JWT_SECRET="replace-with-random-256-bit-key"
JWT_REFRESH_SECRET="replace-with-different-random-256-bit-key"

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# SMS: mock is allowed outside production only
SMS_PROVIDER=mock
ENABLE_QUEUES=false
REDIS_HOST=localhost
REDIS_PORT=6379

# App
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# SMS Configuration
# SMS Provider: mock | unifonic | twilio
SMS_PROVIDER=unifonic

# Unifonic (إذا SMS_PROVIDER=unifonic)
UNIFONIC_API_KEY=your-api-key-here
UNIFONIC_SENDER_ID=CollectiveTrust

# Twilio (إذا SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# Dev login — تحذير: لا تفعّل هذا في الإنتاج أبداً
ENABLE_DEV_LOGIN=true

# بوابات الدفع الإلكتروني
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENT_CALLBACK_URL=http://localhost:3000/payment/callback

# Moyasar
MOYASAR_SECRET_KEY=sk_test_...
# secret_token الذي يُرسله Moyasar في كل webhook — يجب أن يتطابق
MOYASAR_WEBHOOK_SECRET=your_moyasar_webhook_secret_token_here
MOYASAR_CALLBACK_URL=http://localhost:3000/payment/callback

# حد زمني لعكس المعاملات (بالأيام)
REVERSAL_WINDOW_DAYS=90
