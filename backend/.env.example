# Database
DATABASE_URL="postgres://postgres:YOUR_PASSWORD@localhost:5432/stgp_dev?sslmode=disable"

# JWT
JWT_SECRET="replace-with-random-256-bit-key"
JWT_REFRESH_SECRET="replace-with-different-random-256-bit-key"

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# SMS: mock is allowed outside production only
SMS_PROVIDER=mock
ENABLE_QUEUES=false
REDIS_HOST=localhost
REDIS_PORT=6379

# App
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000
# بديل أعلى أولوية من CORS_ORIGINS لقائمة الأصول المسموحة لـ CORS (اختياري)
# ALLOWED_ORIGINS=http://localhost:3000
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# يُستخدم كـ fallback لرابط إعادة التوجيه بعد الدفع إذا لم يُحدَّد PAYMENT_CALLBACK_URL/MOYASAR_CALLBACK_URL
FRONTEND_PUBLIC_URL=http://localhost:3000

# SMS Configuration
# SMS Provider: mock | unifonic | twilio
SMS_PROVIDER=unifonic

# Unifonic (إذا SMS_PROVIDER=unifonic)
UNIFONIC_API_KEY=your-api-key-here
UNIFONIC_SENDER_ID=CollectiveTrust

# Twilio (إذا SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# Dev login — تحذير: لا تفعّل هذا في الإنتاج أبداً
ENABLE_DEV_LOGIN=true

# Google OAuth (تسجيل الدخول عبر Google) — اتركه فارغاً لتعطيل هذه الطريقة
GOOGLE_OAUTH_CLIENT_ID=

# بوابات الدفع الإلكتروني
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENT_CALLBACK_URL=http://localhost:3000/payment/callback

# Moyasar
MOYASAR_SECRET_KEY=sk_test_...
# secret_token الذي يُرسله Moyasar في كل webhook — يجب أن يتطابق
MOYASAR_WEBHOOK_SECRET=your_moyasar_webhook_secret_token_here
# اسم بديل قديم لنفس القيمة أعلاه (fallback إذا MOYASAR_WEBHOOK_SECRET غير مضبوط) — لا تضبط الاثنين معاً
# MOYASAR_WEBHOOK_SECRET_TOKEN=
MOYASAR_CALLBACK_URL=http://localhost:3000/payment/callback
# نقطة نهاية Moyasar API — غيّرها فقط للاختبار ضد بيئة وسيطة
# MOYASAR_API_BASE_URL=https://api.moyasar.com/v1

# حد زمني لعكس المعاملات (بالأيام)
REVERSAL_WINDOW_DAYS=90

# تسجيل دخول المنصّة (Platform/Owner bootstrap) — سر يُستخدم مرة واحدة لإنشاء أول حساب Owner
PLATFORM_BOOTSTRAP_SECRET=replace-with-random-secret

# Web Push (إشعارات المتصفح) — أنشئ زوج مفاتيح VAPID عبر: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# OpenSearch (البحث) — اختياري، يُستخدم فقط إذا كانت ميزة البحث مفعّلة
OPENSEARCH_NODE=http://localhost:9200

# Temporal.io (محرّك سير العمل/الجدولة) — اختياري
TEMPORAL_ADDRESS=localhost:7233

# ===== متغيرات سكربتات الـ Seed (تطوير محلي فقط — لا تُستخدم في الإنتاج) =====
# كلمة مرور موحّدة لكل حسابات المستخدمين المزروعة بالـ seed
SEED_USER_PASSWORD=123456
# كلمة مرور حساب المنصّة (Owner/Support) المزروع بالـ seed
SEED_PLATFORM_PASSWORD=123456
# اسم نمط بيانات الـ seed (إن وُجد أكثر من ملف تعريف)
# SEED_PROFILE=
# تاريخ مرجعي ثابت تُحسب عليه كل الفترات النسبية في الـ seed (ISO date)؛ افتراضياً تاريخ التشغيل الفعلي
# SEED_REFERENCE_DATE=
# يطبع هوية قاعدة البيانات (host/name) قبل تنفيذ أي seed/reset مدمّر — للتأكيد البصري
SEED_PRINT_DB_IDENTITY=true
# حواجز أمان ضد تشغيل seed:reset / seed:backup بالخطأ على قاعدة بيانات غير محلية أو غير تطويرية
SEED_RESET_ALLOW_NON_LOCAL=false
SEED_RESET_ALLOW_NON_DEV_DB=false
# تتحقق منها seed-runtime.ts قبل أي عملية لضمان الاتصال بقاعدة البيانات الصحيحة
# SEED_EXPECTED_DB_HOST=localhost
# SEED_EXPECTED_DB_PORT=5432
# SEED_EXPECTED_DB_NAME=stgp_dev
# اسم سكيمة النسخ الاحتياطي المستخدم بواسطة seed:backup / seed:restore
# SEED_BACKUP_SCHEMA=
# رابط الـ API المستخدم بواسطة seed:smoke-logins للتحقق من تسجيل الدخول الفعلي عبر HTTP
SEED_SMOKE_API_URL=http://localhost:3001/api
