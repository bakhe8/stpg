/// قالب لإنشاء الكيانات الجديدة مع محافظها ومساراتها الافتراضية
model EntityTemplate {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  type        EntityType
  description String?

  /// أيقونة القالب (emoji أو رمز)
  icon String?

  /// هل القالب نشط ويظهر للمستخدمين؟
  isActive Boolean @default(true)

  /// ترتيب العرض
  sortOrder Int @default(0)

  /// الوحدات المُفعَّلة افتراضياً عند إنشاء كيان من هذا القالب
  /// مثال: ["payments","decisions","committees","beneficiaries","auditor"]
  enabledModules Json?

  /// الأهداف/المحافظ المقترحة (مصفوفة JSON: [{name, icon}])
  suggestedGoals Json?

  /// سياسات الكيان الافتراضية
  defaultPolicy Json?

  /// المحافظ الافتراضية (مصفوفة JSON)
  defaultWallets Json?

  /// مسارات الحوكمة الافتراضية (مصفوفة JSON)
  defaultPaths Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entities Entity[]

  @@map("entity_templates")
}

