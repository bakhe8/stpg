# =============================================================
# CollectiveTrustOS / STGP — متغيرات بيئة الإنتاج
# انسخ هذا الملف إلى /opt/collective-trust/.env على الـ VPS
# وعبّئ جميع القيم قبل التشغيل. لا ترفعه إلى git أبداً.
# =============================================================

# ── قاعدة البيانات ──────────────────────────────────────────
# لتوليد كلمة مرور قوية: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# ── JWT ────────────────────────────────────────────────────
# لتوليد: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_CHARS_MIN

# ── منصة الإدارة ───────────────────────────────────────────
# يُستخدم مرة واحدة فقط لإنشاء أول حساب OWNER
PLATFORM_BOOTSTRAP_SECRET=CHANGE_ME_BOOTSTRAP_SECRET

# ── SMS ────────────────────────────────────────────────────
# mock = بدون إرسال فعلي
# unifonic = Unifonic (مزود سعودي موصى به للإنتاج)
SMS_PROVIDER=mock

# Unifonic — مطلوب فقط إذا SMS_PROVIDER=unifonic
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=

# =============================================================
# تعليمات الأمان:
# 1. لا ترفع هذا الملف بعد ملء القيم إلى git أبداً
# 2. احتفظ بنسخة آمنة خارج السيرفر (password manager)
# 3. غيّر JWT_SECRET فوراً عند أي اختراق مشتبه به
# 4. لتوليد كلمات مرور عشوائية: openssl rand -base64 48
# =============================================================
