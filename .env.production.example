# =============================================================
# CollectiveTrustOS / STGP — متغيرات بيئة الإنتاج
# انسخ هذا الملف إلى /opt/collective-trust/.env على الـ VPS
# وعبّئ جميع القيم قبل التشغيل. لا ترفعه إلى git أبداً.
# =============================================================

# ── قاعدة البيانات ──────────────────────────────────────────
# لتوليد كلمة مرور قوية: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_APP_USER=stgp_app
DB_APP_PASSWORD=CHANGE_ME_APP_DB_PASSWORD_HERE

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# ── Search / Workflow ──────────────────────────────────────
# تبقى داخل Docker network في الإنتاج ولا تُفتح للعامة.
OPENSEARCH_NODE=http://opensearch:9200
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
TEMPORAL_ADDRESS=temporal:7233

# ── Host reverse proxy ─────────────────────────────────────
# wbgl.tech يستخدم Nginx على 80/443 لعدة برامج، ثم يمرر STGP إلى هذا المنفذ.
STGP_HTTP_PORT=3080

# ── JWT ────────────────────────────────────────────────────
# لتوليد: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_CHARS_MIN

# ── منصة الإدارة ───────────────────────────────────────────
# يُستخدم مرة واحدة فقط لإنشاء أول حساب OWNER
PLATFORM_BOOTSTRAP_SECRET=CHANGE_ME_BOOTSTRAP_SECRET

# ── OAuth ──────────────────────────────────────────────────
# ضع Client IDs المسموحة كما تظهر في Google/Apple developer consoles.
# يمكن فصل أكثر من قيمة بفاصلة إذا كان لديك web/mobile clients.
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_ID=

# ── Payments ───────────────────────────────────────────────
# Stripe PaymentIntents + signed webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Moyasar hosted invoices + webhook secret_token
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=
# اختياري: اتركه فارغاً لاستخدام https://api.moyasar.com/v1
MOYASAR_API_BASE_URL=
PAYMENT_CALLBACK_URL=https://stpg.wbgl.tech/finance
FRONTEND_PUBLIC_URL=https://stpg.wbgl.tech

# ── SMS ────────────────────────────────────────────────────
# mock = بدون إرسال فعلي
# unifonic = Unifonic (مزود سعودي موصى به للإنتاج)
SMS_PROVIDER=mock

# Unifonic — مطلوب فقط إذا SMS_PROVIDER=unifonic
UNIFONIC_API_KEY=
UNIFONIC_SENDER_ID=

# =============================================================
# تعليمات الأمان:
# 1. لا ترفع هذا الملف بعد ملء القيم إلى git أبداً
# 2. احتفظ بنسخة آمنة خارج السيرفر (password manager)
# 3. غيّر JWT_SECRET فوراً عند أي اختراق مشتبه به
# 4. لتوليد كلمات مرور عشوائية: openssl rand -base64 48
# =============================================================
